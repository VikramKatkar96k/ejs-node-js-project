<!DOCTYPE html>
<html lang="mr">
<head>
  <meta charset="UTF-8">
  <title>कर्ज अर्ज फॉर्म - सॅटिन फिनसर्व्ह लिमिटेड</title>
  <style>
    @page { size: A4; margin: 0; }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background-color: #ffffff;
      font-family: 'Nirmala UI', 'Mangal', 'Noto Sans Devanagari', sans-serif;
      -webkit-print-color-adjust: exact;
    }

    .page {
      position: relative;
      width: 210mm;
      min-height: 297mm;
      padding: 12mm 14mm 14mm 14mm;
      box-sizing: border-box;
      page-break-after: always;
      overflow: hidden;
      color: #000000;
      margin: 0 auto;
      font-size: 10pt;
    }
    .page:last-child { page-break-after: avoid; }

    .top-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 8px; }
    .top-header .logo img { height: 34px; max-width: 150px; object-fit: contain; }
    .top-header .form-title { font-size: 12pt; font-weight: bold; text-decoration: underline; padding-top: 6px; }
    .top-header .date { font-size: 10pt; padding-top: 6px; }

    table.branch-table { border-collapse: collapse; width: 55%; margin: 4px 0 4px auto; }
    table.branch-table td { border: 1px solid #000000; padding: 3px 6px; font-size: 9.5pt; height: 16px; }
    table.branch-table td.lbl { width: 40%; }

    .section-title { font-size: 10.5pt; font-weight: bold; text-decoration: underline; margin: 14px 0 10px 0; }

    .section-bar { background-color: #7d00b3; color: #fff; text-align: center; font-weight: bold; font-size: 10.5pt; padding: 4px 0; margin: 14px 0 10px 0; }
    .section-bar.teal { background-color: #9fd8d3; color: #000; text-align: left; padding-left: 8px; }

    .field-row { margin-bottom: 12px; line-height: 1.5; }

    .fill { display: inline-block; border-bottom: 1px solid #000000; min-width: 120px; height: 13px; }
    .fill.grow { min-width: 300px; }
    .fill.wide { min-width: 420px; }
    .fill.xwide { min-width: 540px; }
    .fill.sm { min-width: 70px; }

    .chk { display: inline-block; width: 12px; height: 12px; border: 1px solid #000000; vertical-align: middle; margin: 0 3px 0 6px; box-sizing: border-box; font-size: 9px; text-align: center; line-height: 11px; }

    .name-cols { display: flex; gap: 20px; margin-top: 2px; }
    .name-cols .nc { flex: 1; text-align: center; }
    .name-cols .nc .line { border-bottom: 1px solid #000000; height: 14px; margin-bottom: 2px; }
    .name-cols .nc .cap { font-size: 8.5pt; }

    table.charges-table { border-collapse: collapse; width: 100%; margin: 6px 0 12px 0; }
    table.charges-table td { border: 1px solid #000000; padding: 4px 6px; font-size: 9.5pt; }
    table.charges-table td.amt { width: 34%; }

    table.ref-table { border-collapse: collapse; width: 100%; margin: 4px 0 10px 0; }
    table.ref-table td { border: 1px solid #000000; padding: 6px 8px; font-size: 9.5pt; vertical-align: top; width: 50%; }
    table.ref-table td .rline { border-bottom: 1px solid #000000; height: 13px; margin: 3px 0 8px 0; }

    .box-received { border: 1px solid #000000; padding: 8px 10px; font-size: 10pt; line-height: 1.6; text-align: justify; margin-bottom: 6px; }
    .summary-box { border: 1px solid #000000; padding: 8px 10px; margin-top: 6px; }

    p.para { font-size: 10pt; line-height: 1.55; text-align: justify; margin: 0 0 10px 0; }

    .foot-note { font-size: 9pt; line-height: 1.4; border-top: 1px dashed #000000; margin-top: 12px; padding-top: 6px; text-align: center; }
    b { font-weight: bold; }
  </style>
</head>
<body>

  <%
    const safeDate = typeof applicationDate !== 'undefined' ? applicationDate : '__ / ____ / 20__';
    const safeProductType = typeof productType !== 'undefined' ? productType : 'ईव्ही पिंक रिक्षा';
    const safeBranchName = typeof branchName !== 'undefined' ? branchName : '';
    const safeBranchCode = typeof branchCode !== 'undefined' ? branchCode : '';
    const safeSource = typeof source !== 'undefined' ? source : 'थेट / डीएसए / डीलर';
    const safeRmName = typeof rmName !== 'undefined' ? rmName : '';
    const safeRmCode = typeof rmCode !== 'undefined' ? rmCode : '';

    // ---------- Applicant ----------
    const safeTitle = typeof title !== 'undefined' ? title : '';
    const safeFirstName = typeof firstName !== 'undefined' ? firstName : '';
    const safeMiddleName = typeof middleName !== 'undefined' ? middleName : '';
    const safeLastName = typeof lastName !== 'undefined' ? lastName : '';
    const safeGender = typeof gender !== 'undefined' ? gender : '';
    const safeMotherName = typeof motherName !== 'undefined' ? motherName : '';
    const safeFatherName = typeof fatherName !== 'undefined' ? fatherName : '';
    const safeSpouseName = typeof spouseName !== 'undefined' ? spouseName : '';
    const safeRelationWithBorrower = typeof relationWithBorrower !== 'undefined' ? relationWithBorrower : '';
    const safeDob = typeof dob !== 'undefined' ? dob : '';
    const safeAge = typeof age !== 'undefined' ? age : '';
    const safeMobile = typeof mobile !== 'undefined' ? mobile : '';
    const safeMaritalStatus = typeof maritalStatus !== 'undefined' ? maritalStatus : '';
    const safeDependents = typeof dependents !== 'undefined' ? dependents : '';
    const safeEducation = typeof education !== 'undefined' ? education : '';
    const safePan = typeof pan !== 'undefined' ? pan : '';
    const safeDrivingLicense = typeof drivingLicense !== 'undefined' ? drivingLicense : '';
    const safeVoterId = typeof voterId !== 'undefined' ? voterId : '';
    const safeCitizen = typeof citizen !== 'undefined' ? citizen : '';
    const safeReligion = typeof religion !== 'undefined' ? religion : '';
    const safeCaste = typeof caste !== 'undefined' ? caste : '';
    const safeResiOwnership = typeof resiOwnership !== 'undefined' ? resiOwnership : '';
    const safeResiStreet = typeof resiStreet !== 'undefined' ? resiStreet : '';
    const safeResiLine1 = typeof resiLine1 !== 'undefined' ? resiLine1 : '';
    const safeResiLine2 = typeof resiLine2 !== 'undefined' ? resiLine2 : '';
    const safeResiCity = typeof resiCity !== 'undefined' ? resiCity : '';
    const safeResiDistrict = typeof resiDistrict !== 'undefined' ? resiDistrict : '';
    const safeResiState = typeof resiState !== 'undefined' ? resiState : '';
    const safeResiCountry = typeof resiCountry !== 'undefined' ? resiCountry : '';
    const safeResiLandmark = typeof resiLandmark !== 'undefined' ? resiLandmark : '';
    const safeResiPincode = typeof resiPincode !== 'undefined' ? resiPincode : '';
    const safeResiPhone = typeof resiPhone !== 'undefined' ? resiPhone : '';
    const safePermOwnership = typeof permOwnership !== 'undefined' ? permOwnership : '';
    const safePermStreet = typeof permStreet !== 'undefined' ? permStreet : '';
    const safePermLine1 = typeof permLine1 !== 'undefined' ? permLine1 : '';
    const safePermLine2 = typeof permLine2 !== 'undefined' ? permLine2 : '';
    const safePermCity = typeof permCity !== 'undefined' ? permCity : '';
    const safePermDistrict = typeof permDistrict !== 'undefined' ? permDistrict : '';
    const safePermState = typeof permState !== 'undefined' ? permState : '';
    const safePermCountry = typeof permCountry !== 'undefined' ? permCountry : '';
    const safePermLandmark = typeof permLandmark !== 'undefined' ? permLandmark : '';
    const safePermPincode = typeof permPincode !== 'undefined' ? permPincode : '';
    const safePermPhone = typeof permPhone !== 'undefined' ? permPhone : '';

    // ---------- Bank ----------
    const safeBankName = typeof bankName !== 'undefined' ? bankName : '';
    const safeBankBranchAddress = typeof bankBranchAddress !== 'undefined' ? bankBranchAddress : '';
    const safeAccountNumber = typeof accountNumber !== 'undefined' ? accountNumber : '';
    const safeAccountType = typeof accountType !== 'undefined' ? accountType : '';
    const safeAccountDuration = typeof accountDuration !== 'undefined' ? accountDuration : '';

    // ---------- Asset ----------
    const safeBrand = typeof brand !== 'undefined' ? brand : '';
    const safeMakerSupplier = typeof makerSupplier !== 'undefined' ? makerSupplier : '';
    const safeModel = typeof model !== 'undefined' ? model : '';
    const safeModelNumber = typeof modelNumber !== 'undefined' ? modelNumber : '';
    const safeRegState = typeof regState !== 'undefined' ? regState : '';
    const safeRegCity = typeof regCity !== 'undefined' ? regCity : '';
    const safeMarginMoney = typeof marginMoney !== 'undefined' ? marginMoney : '';
    const safeLoanAmount = typeof loanAmount !== 'undefined' ? loanAmount : '';
    const safeLoanTenor = typeof loanTenor !== 'undefined' ? String(loanTenor) : '';

    // ---------- Co-applicant 1 ----------
    const safeCo1Title = typeof co1Title !== 'undefined' ? co1Title : '';
    const safeCo1FirstName = typeof co1FirstName !== 'undefined' ? co1FirstName : '';
    const safeCo1MiddleName = typeof co1MiddleName !== 'undefined' ? co1MiddleName : '';
    const safeCo1LastName = typeof co1LastName !== 'undefined' ? co1LastName : '';
    const safeCo1Gender = typeof co1Gender !== 'undefined' ? co1Gender : '';
    const safeCo1MotherName = typeof co1MotherName !== 'undefined' ? co1MotherName : '';
    const safeCo1FatherName = typeof co1FatherName !== 'undefined' ? co1FatherName : '';
    const safeCo1SpouseName = typeof co1SpouseName !== 'undefined' ? co1SpouseName : '';
    const safeCo1RelationWithBorrower = typeof co1RelationWithBorrower !== 'undefined' ? co1RelationWithBorrower : '';
    const safeCo1Dob = typeof co1Dob !== 'undefined' ? co1Dob : '';
    const safeCo1Age = typeof co1Age !== 'undefined' ? co1Age : '';
    const safeCo1Mobile = typeof co1Mobile !== 'undefined' ? co1Mobile : '';
    const safeCo1MaritalStatus = typeof co1MaritalStatus !== 'undefined' ? co1MaritalStatus : '';
    const safeCo1Dependents = typeof co1Dependents !== 'undefined' ? co1Dependents : '';
    const safeCo1Education = typeof co1Education !== 'undefined' ? co1Education : '';
    const safeCo1Pan = typeof co1Pan !== 'undefined' ? co1Pan : '';
    const safeCo1DrivingLicense = typeof co1DrivingLicense !== 'undefined' ? co1DrivingLicense : '';
    const safeCo1VoterId = typeof co1VoterId !== 'undefined' ? co1VoterId : '';
    const safeCo1Citizen = typeof co1Citizen !== 'undefined' ? co1Citizen : '';
    const safeCo1Religion = typeof co1Religion !== 'undefined' ? co1Religion : '';
    const safeCo1Caste = typeof co1Caste !== 'undefined' ? co1Caste : '';
    const safeCo1ResiOwnership = typeof co1ResiOwnership !== 'undefined' ? co1ResiOwnership : '';
    const safeCo1ResiStreet = typeof co1ResiStreet !== 'undefined' ? co1ResiStreet : '';
    const safeCo1ResiLine1 = typeof co1ResiLine1 !== 'undefined' ? co1ResiLine1 : '';
    const safeCo1ResiLine2 = typeof co1ResiLine2 !== 'undefined' ? co1ResiLine2 : '';
    const safeCo1ResiCity = typeof co1ResiCity !== 'undefined' ? co1ResiCity : '';
    const safeCo1ResiDistrict = typeof co1ResiDistrict !== 'undefined' ? co1ResiDistrict : '';
    const safeCo1ResiState = typeof co1ResiState !== 'undefined' ? co1ResiState : '';
    const safeCo1ResiCountry = typeof co1ResiCountry !== 'undefined' ? co1ResiCountry : '';
    const safeCo1ResiLandmark = typeof co1ResiLandmark !== 'undefined' ? co1ResiLandmark : '';
    const safeCo1ResiPincode = typeof co1ResiPincode !== 'undefined' ? co1ResiPincode : '';
    const safeCo1ResiPhone = typeof co1ResiPhone !== 'undefined' ? co1ResiPhone : '';
    const safeCo1PermOwnership = typeof co1PermOwnership !== 'undefined' ? co1PermOwnership : '';
    const safeCo1PermStreet = typeof co1PermStreet !== 'undefined' ? co1PermStreet : '';
    const safeCo1PermLine1 = typeof co1PermLine1 !== 'undefined' ? co1PermLine1 : '';
    const safeCo1PermLine2 = typeof co1PermLine2 !== 'undefined' ? co1PermLine2 : '';
    const safeCo1PermCity = typeof co1PermCity !== 'undefined' ? co1PermCity : '';
    const safeCo1PermDistrict = typeof co1PermDistrict !== 'undefined' ? co1PermDistrict : '';
    const safeCo1PermState = typeof co1PermState !== 'undefined' ? co1PermState : '';
    const safeCo1PermCountry = typeof co1PermCountry !== 'undefined' ? co1PermCountry : '';
    const safeCo1PermLandmark = typeof co1PermLandmark !== 'undefined' ? co1PermLandmark : '';
    const safeCo1PermPincode = typeof co1PermPincode !== 'undefined' ? co1PermPincode : '';
    const safeCo1PermPhone = typeof co1PermPhone !== 'undefined' ? co1PermPhone : '';

    // ---------- References ----------
    const safeRef1Name = typeof ref1Name !== 'undefined' ? ref1Name : '';
    const safeRef1Address = typeof ref1Address !== 'undefined' ? ref1Address : '';
    const safeRef1Pin = typeof ref1Pin !== 'undefined' ? ref1Pin : '';
    const safeRef1Occupation = typeof ref1Occupation !== 'undefined' ? ref1Occupation : '';
    const safeRef1Tel = typeof ref1Tel !== 'undefined' ? ref1Tel : '';
    const safeRef1Mobile = typeof ref1Mobile !== 'undefined' ? ref1Mobile : '';
    const safeRef2Name = typeof ref2Name !== 'undefined' ? ref2Name : '';
    const safeRef2Address = typeof ref2Address !== 'undefined' ? ref2Address : '';
    const safeRef2Pin = typeof ref2Pin !== 'undefined' ? ref2Pin : '';
    const safeRef2Occupation = typeof ref2Occupation !== 'undefined' ? ref2Occupation : '';
    const safeRef2Tel = typeof ref2Tel !== 'undefined' ? ref2Tel : '';
    const safeRef2Mobile = typeof ref2Mobile !== 'undefined' ? ref2Mobile : '';

    // ---------- Summary / Page 4 ----------
    const safeAppliedAmount = typeof appliedAmount !== 'undefined' ? appliedAmount : '';
    const safeTenorApplied = typeof tenorApplied !== 'undefined' ? tenorApplied : '';
    const safeRoi = typeof roi !== 'undefined' ? roi : '';
    const safePurpose = typeof purpose !== 'undefined' ? purpose : '';
    const safeReceivedFrom = typeof receivedFrom !== 'undefined' ? receivedFrom : '';
  %>

  <!-- ================= PAGE 1 ================= -->
  <div class="page">
    <div class="top-header">
      <div class="logo"><img src="/assets/SFL-logo.png" alt="Satin Finserv Limited Logo"></div>
      <div class="form-title">कर्ज अर्ज फॉर्म</div>
      <div class="date">दिनांक: <%= safeDate %></div>
    </div>

    <table class="branch-table">
      <tr><td class="lbl">शाखेचे नाव</td><td><%= safeBranchName %></td></tr>
      <tr><td class="lbl">शाखा कोड</td><td><%= safeBranchCode %></td></tr>
      <tr><td class="lbl">स्रोत</td><td><%= safeSource %></td></tr>
      <tr><td class="lbl">आरएमचे नाव</td><td><%= safeRmName %></td></tr>
      <tr><td class="lbl">आरएम कोड</td><td><%= safeRmCode %></td></tr>
      <tr><td class="lbl">उत्पादन प्रकार</td><td><%= safeProductType %></td></tr>
    </table>

    <div class="section-title">अर्जदाराचे वैयक्तिक तपशील</div>

    <div class="field-row">पदवी : <span class="chk"><%= safeTitle==='श्रीमती'?'✓':'' %></span> श्रीमती <span class="chk"><%= safeTitle==='कुमारी'?'✓':'' %></span> कुमारी <span class="chk"><%= safeTitle==='श्री'?'✓':'' %></span> श्री</div>

    <div class="field-row">
      नाव:
      <div class="name-cols">
        <div class="nc"><div class="line"><%= safeFirstName %></div><div class="cap">पहिले नाव</div></div>
        <div class="nc"><div class="line"><%= safeMiddleName %></div><div class="cap">मधले नाव</div></div>
        <div class="nc"><div class="line"><%= safeLastName %></div><div class="cap">आडनाव</div></div>
      </div>
    </div>

    <div class="field-row">लिंग: <span class="chk"><%= safeGender==='पुरुष'?'✓':'' %></span> पुरुष <span class="chk"><%= safeGender==='स्त्री'?'✓':'' %></span> स्त्री <span class="chk"><%= safeGender==='इतर'?'✓':'' %></span> इतर</div>
    <div class="field-row">आईचे पूर्ण नाव: <span class="fill xwide"><%= safeMotherName %></span></div>
    <div class="field-row">वडिलांचे पूर्ण नाव: <span class="fill xwide"><%= safeFatherName %></span></div>
    <div class="field-row">पती/पत्नीचे पूर्ण नाव: <span class="fill xwide"><%= safeSpouseName %></span></div>
    <div class="field-row">कर्जदाराशी नाते: <span class="fill wide"><%= safeRelationWithBorrower %></span></div>

    <div class="field-row">जन्मतारीख: <span class="fill"><%= safeDob %></span> &nbsp; वय: <span class="fill sm"><%= safeAge %></span> (वर्षांमध्ये) मोबाईल: <span class="fill grow"><%= safeMobile %></span></div>
    <div class="field-row">वैवाहिक स्थिती: <span class="chk"><%= safeMaritalStatus==='विवाहित'?'✓':'' %></span> विवाहित <span class="chk"><%= safeMaritalStatus==='अविवाहित'?'✓':'' %></span> अविवाहित &nbsp;&nbsp; अवलंबितांची संख्या: <span class="fill grow"><%= safeDependents %></span></div>
    <div class="field-row">शैक्षणिक पात्रता: <span class="chk"><%= safeEducation==='पदवीपूर्व'?'✓':'' %></span> पदवीपूर्व <span class="chk"><%= safeEducation==='पदवीधर'?'✓':'' %></span> पदवीधर <span class="chk"><%= safeEducation==='पदव्युत्तर'?'✓':'' %></span> पदव्युत्तर <span class="chk"><%= safeEducation==='इतर'?'✓':'' %></span> इतर <span class="fill"><%= safeEducation==='इतर'?safeEducation:'' %></span></div>
    <div class="field-row">पॅन कार्ड क्रमांक: <span class="fill"><%= safePan %></span> ड्रायव्हिंग लायसन्स क्र. <span class="fill"><%= safeDrivingLicense %></span> मतदार ओळखपत्र: <span class="fill"><%= safeVoterId %></span></div>
    <div class="field-row">भारताचे नागरिक: <span class="chk"><%= safeCitizen==='होय'?'✓':'' %></span> होय <span class="chk"><%= safeCitizen==='नाही'?'✓':'' %></span> नाही &nbsp; धर्म: <span class="fill"><%= safeReligion %></span> जात: <span class="chk"><%= safeCaste==='खुला'?'✓':'' %></span> खुला <span class="chk"><%= safeCaste==='एसटी/एससी'?'✓':'' %></span> एसटी/एससी</div>

    <div class="field-row" style="margin-bottom: 6px;">रहिवासी पत्ता:</div>
    <div class="field-row">मालकी स्थिती &nbsp;&nbsp;&nbsp; <span class="chk"><%= safeResiOwnership==='स्वतःचे'?'✓':'' %></span> स्वतःचे <span class="chk"><%= safeResiOwnership==='पालकांचे'?'✓':'' %></span> पालकांचे <span class="chk"><%= safeResiOwnership==='नातेवाईकांचे'?'✓':'' %></span> नातेवाईकांचे <span class="chk"><%= safeResiOwnership==='भाड्याचे'?'✓':'' %></span> भाड्याचे</div>
    <div class="field-row">रस्त्याचे नाव/पोस्ट ऑफिस आणि पोलीस स्टेशन: <span class="fill wide"><%= safeResiStreet %></span></div>
    <div class="field-row">पत्ता ओळ १: <span class="fill wide"><%= safeResiLine1 %></span></div>
    <div class="field-row">पत्ता ओळ २: <span class="fill wide"><%= safeResiLine2 %></span></div>
    <div class="field-row">शहर: <span class="fill"><%= safeResiCity %></span> जिल्हा: <span class="fill"><%= safeResiDistrict %></span> राज्य: <span class="fill"><%= safeResiState %></span></div>
    <div class="field-row">देश: <span class="fill"><%= safeResiCountry %></span> जवळची खूण: <span class="fill grow"><%= safeResiLandmark %></span></div>
    <div class="field-row">पिनकोड: <span class="fill grow"><%= safeResiPincode %></span> फोन: <span class="fill grow"><%= safeResiPhone %></span></div>

    <div class="field-row" style="margin-top: 8px;"><b>कायमचा पत्ता:</b></div>
    <div class="field-row">मालकी स्थिती &nbsp;&nbsp;&nbsp; <span class="chk"><%= safePermOwnership==='स्वतःचे'?'✓':'' %></span> स्वतःचे <span class="chk"><%= safePermOwnership==='पालकांचे'?'✓':'' %></span> पालकांचे <span class="chk"><%= safePermOwnership==='नातेवाईकांचे'?'✓':'' %></span> नातेवाईकांचे <span class="chk"><%= safePermOwnership==='भाड्याचे'?'✓':'' %></span> भाड्याचे</div>
    <div class="field-row">कायमचा पत्ता: रस्त्याचे नाव/पोस्ट ऑफिस आणि पोलीस स्टेशन: <span class="fill grow"><%= safePermStreet %></span></div>
    <div class="field-row">पत्ता ओळ १: <span class="fill wide"><%= safePermLine1 %></span></div>
    <div class="field-row">पत्ता ओळ २: <span class="fill wide"><%= safePermLine2 %></span></div>
  </div>

  <!-- ================= PAGE 2 ================= -->
  <div class="page">
    <div class="field-row">शहर: <span class="fill"><%= safePermCity %></span> जिल्हा: <span class="fill"><%= safePermDistrict %></span> राज्य: <span class="fill"><%= safePermState %></span></div>
    <div class="field-row">देश: <span class="fill"><%= safePermCountry %></span> जवळची खूण: <span class="fill grow"><%= safePermLandmark %></span></div>
    <div class="field-row">पिनकोड: <span class="fill grow"><%= safePermPincode %></span> फोन: <span class="fill grow"><%= safePermPhone %></span></div>

    <div class="section-title">बँक तपशील</div>
    <div class="field-row">बँकेचे नाव: <span class="fill wide"><%= safeBankName %></span></div>
    <div class="field-row">बँकेच्या शाखेचा पत्ता: <span class="fill wide"><%= safeBankBranchAddress %></span></div>
    <div class="field-row">खाते क्रमांक: <span class="fill wide"><%= safeAccountNumber %></span></div>
    <div class="field-row">खात्याचा प्रकार: <span class="fill wide"><%= safeAccountType %></span></div>
    <div class="field-row">सध्याच्या बँकेतील खात्याचा कालावधी: <span class="fill grow"><%= safeAccountDuration %></span></div>

    <div class="section-title">मालमत्ता तपशील</div>
    <div class="field-row">ब्रँड: <span class="fill grow"><%= safeBrand %></span> निर्माता/पुरवठादार: <span class="fill grow"><%= safeMakerSupplier %></span></div>
    <div class="field-row">मॉडेल: <span class="fill grow"><%= safeModel %></span> मॉडेल क्रमांक: <span class="fill grow"><%= safeModelNumber %></span></div>
