          <tr><td style="border:none; padding:2px 0;">पदनाम:</td><td style="border:none; padding:2px 0; font-weight:bold;"><%= safeEmployeeDesignation %></td></tr>
          <tr><td style="border:none; padding:2px 0;">शाखा:</td><td style="border:none; padding:2px 0; font-weight:bold;"><%= safeEmployeeBranch %></td></tr>
        </table>
        <img class="sign-img" src="/assets/sign.png" alt="Signature">
        <div style="margin-top: 12px;">शिक्का आणि स्वाक्षरी.........</div>
