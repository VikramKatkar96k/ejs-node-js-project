<!DOCTYPE html>
<html lang="mr">
<head>
  <meta charset="UTF-8">
  <title>कर्ज अर्ज फॉर्म - Satin Finserv Limited</title>
  <style>
    @page { size: A4; margin: 0; }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      background-color: #ffffff;
      font-family: 'Nirmala UI', 'Mangal', 'Kokila', Arial, sans-serif;
      color: #000;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .page {
      position: relative;
      width: 210mm;
      min-height: 297mm;
      padding: 14mm 16mm;
      box-sizing: border-box;
      page-break-after: always;
      margin: 0 auto;
    }
    .page:last-child { page-break-after: avoid; }

    /* Header */
    .app-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 6px;
    }
    .app-header .logo { height: 46px; width: auto; }
    .app-title {
      font-size: 15pt;
      font-weight: bold;
      text-align: center;
      flex: 1 1 auto;
    }
    .app-date { font-size: 11pt; white-space: nowrap; }

    /* Branch details table (top right) */
    .branch-table {
      border-collapse: collapse;
      width: 58%;
      margin: 4px 0 10px auto;
      font-size: 10pt;
    }
    .branch-table td {
      border: 1px solid #000;
      padding: 3px 6px;
      height: 16px;
    }
    .branch-table td.k { width: 42%; }

    /* Section headings */
    .sec-heading {
      font-size: 11pt;
      font-weight: bold;
      text-decoration: underline;
      margin: 14px 0 8px 0;
    }
    .sub-label { margin: 10px 0 2px 0; }

    /* Rows and fill-in lines */
    .row {
      display: flex;
      align-items: flex-end;
      gap: 6px;
      flex-wrap: nowrap;
      margin: 9px 0;
      font-size: 10.5pt;
      line-height: 1.3;
    }
    .lbl { white-space: nowrap; }
    .line {
      flex: 1 1 auto;
      min-width: 0;
      border-bottom: 1px solid #000;
      min-height: 1.15em;
      padding: 0 3px;
      font-weight: bold;
      word-break: break-word;
    }

    /* Checkbox */
    .cb {
      position: relative;
      display: inline-block;
      width: 12px;
      height: 12px;
      border: 1px solid #000;
      vertical-align: middle;
      margin: 0 4px 2px 6px;
    }
    .cb.on::after {
      content: '\2713';
      position: absolute;
      left: -1px;
      top: -6px;
      width: 14px;
      text-align: center;
      font-size: 14px;
      font-weight: bold;
      line-height: 1;
    }
    .cb-lbl { white-space: nowrap; }

    /* Three-column name row */
    .name-col { flex: 1 1 0; text-align: center; }
    .name-col .line { display: block; min-height: 1.15em; text-align: center; }
    .name-col .cap { font-size: 9pt; }

    /* Reference details table */
    .ref-table {
      border-collapse: collapse;
      width: 100%;
      margin-top: 12px;
      font-size: 10pt;
    }
    .ref-table td { border: 1px solid #000; padding: 6px 8px; vertical-align: top; }
    .ref-head {
      background: #a9d5cf;
      font-weight: bold;
      font-size: 10.5pt;
    }
    .ref-sub { font-weight: bold; }
    .ref-field { margin: 8px 0; }
    .ref-field .u {
      display: inline-block;
      border-bottom: 1px solid #000;
      min-width: 160px;
      font-weight: bold;
      padding: 0 3px;
    }
    .ref-field .u.long { min-width: 74%; }

    /* Purple section banner */
    .banner {
      background: #9b1fc1;
      color: #ffffff;
      text-align: center;
      font-weight: bold;
      font-size: 11.5pt;
      padding: 6px 0;
      margin: 16px 0 10px 0;
    }

    /* Summary box */
    .box {
      border: 1px solid #000;
      padding: 10px 12px;
    }

    /* Intro paragraph box */
    .intro-box {
      border: 1px solid #999;
      padding: 10px 12px;
      font-size: 10.5pt;
      line-height: 1.5;
      text-align: justify;
    }
    .intro-box .u {
      display: inline-block;
      border-bottom: 1px solid #000;
      min-width: 320px;
      font-weight: bold;
      padding: 0 3px;
    }

    p { font-size: 10.5pt; line-height: 1.5; text-align: justify; margin: 8px 0; }

    /* Fee schedule table */
    .fee-table {
      border-collapse: collapse;
      width: 100%;
      font-size: 10pt;
      margin: 4px 0 12px 0;
    }
    .fee-table td { border: 1px solid #000; padding: 5px 8px; vertical-align: top; }
    .fee-table td.amt { width: 30%; }

    .points p { margin: 5px 0; }

    /* Compact typography for the dense charges/declaration pages */
    .compact p { font-size: 9pt; line-height: 1.34; margin: 5px 0; }
    .compact .banner { font-size: 11pt; padding: 4px 0; margin: 10px 0 7px 0; }
    .compact .intro-box { padding: 7px 10px; font-size: 9.5pt; line-height: 1.4; }
    .compact .fee-table { font-size: 8.5pt; margin: 3px 0 9px 0; }
    .compact .fee-table td { padding: 3px 7px; }
    .compact .sec-heading { margin: 9px 0 5px 0; }
    .compact .points p { margin: 4px 0; }

    /* Registered office footer */
    .reg-office {
      border-top: 2px dashed #000;
      padding-top: 6px;
      margin-top: 14px;
      font-size: 9.5pt;
      line-height: 1.5;
    }
    .credit-note { font-size: 10pt; margin: 12px 0 6px 4px; }

    /* ---- Consent letter (page 6) ---- */
    .sheet-logo { text-align: right; margin-bottom: 4px; }
    .sheet-logo img { height: 42px; width: auto; }
    .center-title { text-align: center; font-weight: bold; font-size: 13pt; text-decoration: underline; margin: 2px 0 18px 0; }
    .consent-row { margin: 8px 0; font-size: 10.5pt; }
    .consent-row .u { display: inline-block; border-bottom: 1px solid #000; min-width: 210px; font-weight: bold; padding: 0 3px; }
    .consent-intro { font-weight: bold; font-size: 10.5pt; margin: 10px 0 7px 0; }
    .consent-list p { font-size: 9pt; line-height: 1.3; text-align: justify; margin: 4px 0; }
    .doc-list { margin: 3px 0 3px 22px; font-size: 10pt; line-height: 1.45; }
    .sign3 { display: flex; justify-content: space-between; margin-top: 18px; text-align: center; font-size: 10pt; }
    .sign3 .col { width: 30%; }
    .sign3 .sig-cap { margin-bottom: 26px; }
    .sign3 .sig-line { border-top: 1px solid #000; padding-top: 4px; font-weight: bold; }
    .sfl-footer { text-align: center; font-size: 9pt; line-height: 1.5; margin-top: 12px; }
    .sfl-footer .co { font-weight: bold; font-size: 10.5pt; }

    /* ---- Sanction letter / KFS (pages 7-9) ---- */
    .san-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    .san-title { font-weight: bold; font-size: 12pt; line-height: 1.4; }
    .san-logo img { height: 40px; width: auto; }
    .san-field { font-size: 10pt; margin: 6px 0; }
    .san-field .u { display: inline-block; border-bottom: 1px solid #000; min-width: 200px; font-weight: bold; padding: 0 3px; }
    .san-para { font-size: 9.6pt; line-height: 1.45; text-align: justify; margin: 8px 0; }
    .san-h { font-weight: bold; font-size: 11pt; text-decoration: underline; margin: 10px 0 6px 0; }
    .san-sub { font-weight: bold; font-size: 10.5pt; margin: 6px 0; }
    .kfs-table { border-collapse: collapse; width: 100%; font-size: 9.2pt; margin: 6px 0; }
    .kfs-table td { border: 1px solid #000; padding: 4px 7px; vertical-align: top; }
    .kfs-table td.sr { width: 6%; text-align: center; }
    .kfs-table td.val { width: 44%; }
    .kfs-shade td { background: #d2d2d2; font-weight: bold; }
    .san-list p { font-size: 9.3pt; line-height: 1.4; text-align: justify; margin: 6px 0; }
    .san-bullets { margin: 4px 0 4px 26px; }
    .san-bullets li { font-size: 9.3pt; line-height: 1.4; margin: 6px 0; }
    .san-footer { position: absolute; bottom: 12mm; left: 16mm; right: 16mm; box-sizing: border-box; }
    .san-footer .pg { text-align: right; font-size: 9.5pt; color: #666; margin-bottom: 6px; }
    .san-footer .borrowers { display: flex; justify-content: space-between; font-size: 9.5pt; }
    .san-sign-block { font-size: 10pt; line-height: 1.7; margin-top: 6px; }
  </style>
</head>
<body>
<%
  // ---- Data (from JSON) with safe fallbacks ----
  const branch      = locals.branch      || {};
  const applicant   = locals.applicant   || {};
  const coApplicant = locals.coApplicant || {};
  const bank        = locals.bank        || {};
  const asset       = locals.asset       || {};
  const references  = locals.references  || [{}, {}];
  const summary     = locals.summary     || {};
  const ref0 = references[0] || {};
  const ref1 = references[1] || {};

  const fullName = (d) => [d.firstName, d.middleName, d.lastName].filter(Boolean).join(' ');
  const applicantName = (locals.intro && locals.intro.applicantName) || fullName(applicant);

  // ---- HTML helpers ----
  const val  = (v) => (v == null ? '' : String(v));
  const line = (v, style) => '<span class="line"' + (style ? ' style="' + style + '"' : '') + '>' + val(v) + '</span>';
  const cb   = (on) => '<span class="cb' + (on ? ' on' : '') + '"></span>';
  const opt  = (sel, match, label) => cb(val(sel) === match) + '<span class="cb-lbl">' + label + '</span>';

  // Repeated identity block (applicant / co-applicant)
  function idBlock(d) {
    const r = d || {};
    return `
    <div class="row"><span class="lbl">पदवी :</span> ${opt(r.title,'श्रीमती','श्रीमती')} ${opt(r.title,'कुमारी','कुमारी')} ${opt(r.title,'श्री','श्री')}</div>
    <div class="row"><span class="lbl">नाव:</span>
      <div class="name-col">${line(r.firstName)}<span class="cap">पहिले नाव</span></div>
      <div class="name-col">${line(r.middleName)}<span class="cap">मधले नाव</span></div>
      <div class="name-col">${line(r.lastName)}<span class="cap">आडनाव</span></div>
    </div>
    <div class="row"><span class="lbl">लिंग:</span> ${opt(r.gender,'पुरुष','पुरुष')} ${opt(r.gender,'स्त्री','स्त्री')} ${opt(r.gender,'इतर','इतर')}</div>
    <div class="row"><span class="lbl">आईचे पूर्ण नाव:</span> ${line(r.motherName)}</div>
    <div class="row"><span class="lbl">वडिलांचे पूर्ण नाव:</span> ${line(r.fatherName)}</div>
    <div class="row"><span class="lbl">पती/पत्नीचे पूर्ण नाव:</span> ${line(r.spouseName)}</div>
    <div class="row"><span class="lbl">कर्जदाराशी नाते:</span> ${line(r.relation)}</div>
    <div class="row"><span class="lbl">जन्मतारीख:</span> ${line(r.dob,'flex:0 0 150px')} <span class="lbl">वय:</span> ${line(r.age,'flex:0 0 80px')} <span class="lbl">(वर्षांमध्ये)</span> <span class="lbl">मोबाईल:</span> ${line(r.mobile)}</div>
    <div class="row"><span class="lbl">वैवाहिक स्थिती:</span> ${opt(r.maritalStatus,'विवाहित','विवाहित')} ${opt(r.maritalStatus,'अविवाहित','अविवाहित')} <span class="lbl" style="margin-left:14px">अवलंबितांची संख्या:</span> ${line(r.dependents)}</div>
    <div class="row"><span class="lbl">शैक्षणिक पात्रता:</span> ${opt(r.education,'पदवीपूर्व','पदवीपूर्व')} ${opt(r.education,'पदवीधर','पदवीधर')} ${opt(r.education,'पदव्युत्तर','पदव्युत्तर')} ${opt(r.education,'इतर','इतर')} ${line(r.educationOther)}</div>
    <div class="row"><span class="lbl">पॅन कार्ड क्रमांक:</span> ${line(r.pan)} <span class="lbl">ड्रायव्हिंग लायसन्स क्र.</span> ${line(r.drivingLicense)} <span class="lbl">मतदार ओळखपत्र:</span> ${line(r.voterId)}</div>
    <div class="row"><span class="lbl">भारताचे नागरिक:</span> ${opt(r.indianCitizen,'होय','होय')} ${opt(r.indianCitizen,'नाही','नाही')} <span class="lbl" style="margin-left:12px">धर्म:</span> ${line(r.religion,'flex:0 0 120px')} <span class="lbl">जात:</span> ${opt(r.caste,'खुला','खुला')} ${opt(r.caste,'एसटी/एससी','एसटी/एससी')} ${cb(val(r.caste)==='इतर')}</div>
    `;
  }

  const ownerRow  = (sel) => `<div class="row"><span class="lbl" style="margin-right:14px">मालकी स्थिती</span> ${opt(sel,'स्वतःचे','स्वतःचे')} ${opt(sel,'पालकांचे','पालकांचे')} ${opt(sel,'नातेवाईकांचे','नातेवाईकांचे')} ${opt(sel,'भाड्याचे','भाड्याचे')}</div>`;
  const streetRow = (prefix, v) => `<div class="row"><span class="lbl">${prefix}रस्त्याचे नाव/पोस्ट ऑफिस आणि पोलीस स्टेशन:</span> ${line(v)}</div>`;
  const addrLine  = (n, v) => `<div class="row"><span class="lbl">पत्ता ओळ ${n}:</span> ${line(v)}</div>`;
  const cityRow   = (a) => `<div class="row"><span class="lbl">शहर:</span> ${line((a||{}).city)} <span class="lbl">जिल्हा:</span> ${line((a||{}).district)} <span class="lbl">राज्य:</span> ${line((a||{}).state)}</div>`;
  const countryRow= (a) => `<div class="row"><span class="lbl">देश:</span> ${line((a||{}).country)} <span class="lbl">जवळची खूण:</span> ${line((a||{}).landmark)}</div>`;
  const pinRow    = (a) => `<div class="row"><span class="lbl">पिनकोड:</span> ${line((a||{}).pincode)} <span class="lbl">फोन:</span> ${line((a||{}).phone)}</div>`;

  const aRes = applicant.residential   || {};
  const aPer = applicant.permanent     || {};
  const cRes = coApplicant.residential || {};
  const cPer = coApplicant.permanent   || {};

  function refCell(r) {
    const x = r || {};
    return `
      <div class="ref-field">नाव <span class="u long">${val(x.name)}</span></div>
      <div class="ref-field">पत्ता <span class="u long">${val(x.address)}</span><br><br><span class="u long"></span> पिन <span class="u">${val(x.pin)}</span></div>
      <div class="ref-field">व्यवसाय <span class="u long">${val(x.occupation)}</span></div>
      <div class="ref-field">दूरध्वनी क्र. <span class="u long">${val(x.phone)}</span></div>
      <div class="ref-field">मोबाईल क्र. <span class="u long">${val(x.mobile)}</span></div>
    `;
  }

  // ---- Consent + Sanction data ----
  const sanction  = locals.sanction || {};
  const sanDate   = sanction.letterDate || {};
  const applName  = fullName(applicant);
  const coName    = fullName(coApplicant);
  const co2       = locals.coApplicant2 || {};
  const co2Name   = fullName(co2);
  const money = (v) => (v == null || v === '') ? '__________' : val(v);
%>

<!-- ============ PAGE 1 ============ -->
<div class="page">
  <div class="app-header">
    <img class="logo" src="/assets/SFL-logo.png" alt="Satin Finserv Limited">
    <div class="app-title">कर्ज अर्ज फॉर्म</div>
    <div class="app-date">दिनांक: <%= branch.dateDay || '__' %> / <%= branch.dateMonth || '____' %> / 20<%= branch.dateYear || '__' %></div>
  </div>

  <table class="branch-table">
    <tr><td class="k">शाखेचे नाव</td><td><%= branch.branchName || '' %></td></tr>
    <tr><td class="k">शाखा कोड</td><td><%= branch.branchCode || '' %></td></tr>
    <tr><td class="k">स्त्रोत</td><td><%= branch.source || 'थेट / डीएसए / डीलर' %></td></tr>
    <tr><td class="k">आरएमचे नाव</td><td><%= branch.rmName || '' %></td></tr>
    <tr><td class="k">आरएम कोड</td><td><%= branch.rmCode || '' %></td></tr>
    <tr><td class="k">उत्पादन प्रकार</td><td><%= branch.productType || 'ईव्ही पिंक रिक्षा' %></td></tr>
  </table>

  <div class="sec-heading">अर्जदाराचे वैयक्तिक तपशील</div>
  <%- idBlock(applicant) %>

  <div class="sub-label">रहिवासी पत्ता:</div>
  <%- ownerRow(aRes.ownership) %>
  <%- streetRow('', aRes.street) %>
  <%- addrLine(1, aRes.line1) %>
  <%- addrLine(2, aRes.line2) %>
  <%- cityRow(aRes) %>
  <%- countryRow(aRes) %>
  <%- pinRow(aRes) %>

  <div class="sub-label">कायमचा पत्ता:</div>
  <%- ownerRow(aPer.ownership) %>
  <%- streetRow('कायमचा पत्ता: ', aPer.street) %>
  <%- addrLine(1, aPer.line1) %>
  <%- addrLine(2, aPer.line2) %>
</div>

<!-- ============ PAGE 2 ============ -->
<div class="page">
  <%- cityRow(aPer) %>
  <%- countryRow(aPer) %>
  <%- pinRow(aPer) %>

  <div class="sec-heading">बँक तपशील</div>
  <div class="row"><span class="lbl">बँकेचे नाव:</span> <%- line(bank.name) %></div>
  <div class="row"><span class="lbl">बँकेच्या शाखेचा पत्ता:</span> <%- line(bank.branchAddress) %></div>
  <div class="row"><span class="lbl">खाते क्रमांक:</span> <%- line(bank.accountNumber) %></div>
  <div class="row"><span class="lbl">खात्याचा प्रकार:</span> <%- line(bank.accountType) %></div>
  <div class="row"><span class="lbl">सध्याच्या बँकेतील खात्याचा कालावधी:</span> <%- line(bank.duration) %></div>

  <div class="sec-heading">मालमत्ता तपशील</div>
  <div class="row"><span class="lbl">ब्रँड:</span> <%- line(asset.brand) %> <span class="lbl" style="font-weight:bold">निर्माता/पुरवठादार:</span> <%- line(asset.manufacturer) %></div>
  <div class="row"><span class="lbl">मॉडेल:</span> <%- line(asset.model) %> <span class="lbl">मॉडेल क्रमांक:</span> <%- line(asset.modelNumber) %></div>
  <div class="row"><span class="lbl">नोंदणीचे राज्य:</span> <%- line(asset.regState) %> <span class="lbl">नोंदणीचे शहर:</span> <%- line(asset.regCity) %></div>
  <div class="row"><span class="lbl">भरलेले मार्जिन मनी:</span> <%- line(asset.marginMoney) %> <span class="lbl">कर्जाची रक्कम:</span> <%- line(asset.loanAmount) %></div>
  <div class="row"><span class="lbl">कर्जाची मुदत (महिन्यांमध्ये)</span> <%- cb(String(asset.loanTenure)==='12') %> 12 <%- cb(String(asset.loanTenure)==='24') %> 24 <%- cb(String(asset.loanTenure)==='36') %> 36 <%- cb(String(asset.loanTenure)==='48') %> 48 <%- cb(String(asset.loanTenure)==='60') %> 60</div>

  <div class="sec-heading">सह-अर्जदार १ वैयक्तिक तपशील</div>
  <%- idBlock(coApplicant) %>

  <div class="sub-label">रहिवासी पत्ता:</div>
  <%- ownerRow(cRes.ownership) %>
  <%- streetRow('', cRes.street) %>
  <%- addrLine(1, cRes.line1) %>
  <%- addrLine(2, cRes.line2) %>
  <%- cityRow(cRes) %>
</div>

<!-- ============ PAGE 3 ============ -->
<div class="page">
  <%- countryRow(cRes) %>
  <%- pinRow(cRes) %>

  <div class="sub-label">कायमचा पत्ता:</div>
  <%- ownerRow(cPer.ownership) %>
  <%- streetRow('कायमचा पत्ता: ', cPer.street) %>
  <%- addrLine(1, cPer.line1) %>
  <%- addrLine(2, cPer.line2) %>
  <%- cityRow(cPer) %>
  <%- countryRow(cPer) %>
  <%- pinRow(cPer) %>

  <table class="ref-table">
    <tr><td class="ref-head" colspan="2">संदर्भाचे तपशील</td></tr>
    <tr><td class="ref-sub" style="width:50%">संदर्भ १</td><td class="ref-sub" style="width:50%">संदर्भ २</td></tr>
    <tr>
      <td><%- refCell(ref0) %></td>
      <td><%- refCell(ref1) %></td>
    </tr>
  </table>

  <div class="banner">अर्जाचा सारांश</div>
  <div class="box">
    <div class="row"><span class="lbl">मागणी केलेली रक्कम (INR):</span> <%- line(summary.requestedAmount) %></div>
    <div class="row"><span class="lbl">मागणी केलेली मुदत (महिने):</span> <%- line(summary.requestedTenure) %></div>
    <div class="row"><span class="lbl">व्याजदर (%):</span> <%- line(summary.interestRate) %></div>
    <div class="row"><span class="lbl">कर्जाचा उद्देश:</span> <%- line(summary.loanPurpose) %></div>
  </div>

