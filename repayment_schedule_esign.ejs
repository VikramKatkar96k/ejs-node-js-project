<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Repayment Schedule - Satin Finserv Limited</title>
  <style>
    /* A4 Dimensions and Page breaks for PDF engines */
  @page {
    size: A4;
    margin: 8mm;
}

html,
body {
    margin: 0;
    padding: 0;
    font-family: Arial, Helvetica, sans-serif;
}

.page {
    position: relative;
    width: 100%;
    min-height: 277mm;
    box-sizing: border-box;
    page-break-after: always;
}

/* ANNEX C */
.annex-title {
    text-align: right;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 25px;
}

/* Heading */
.title {
    text-align: center;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    margin-bottom: 25px;
}

/* Table */
table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
}

table,
th,
td {
    border: 1px solid #444;
}

th {
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    padding: 8px 4px;
    line-height: 1.3;
}

td {
    font-size: 13px;
    text-align: center;
    padding: 3px;
    line-height: 1.2;
}

/* Footer */
.footer-container {
    margin-top: 20px;
    width: 100%;
}

.esign-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}

.esign-block {
    width: 220px;
    text-align: center;
    font-size: 11px;
}

.esign-name {
    font-weight: bold;
}

.esign-underline {
    border-top: 1px solid #000;
    margin-top: 4px;
    padding-top: 2px;
}

.stamp-duty-text {
    margin-top: 10px;
    text-align: center;
    font-size: 10px;
    line-height: 1.3;
}

@media print {

    .page {
        page-break-after: always;
    }

    table,
    tr,
    td,
    th,
    .footer-container {
        page-break-inside: avoid;
    }
}
  </style>
</head>
<body>

  <% 
    // Safely define layout variable defaults
    const safeBorrowerName = typeof borrowerName !== 'undefined' ? borrowerName : 'SUKHDEEP KAUR';
    const safeBorrowerSignTime = typeof borrowerSignTime !== 'undefined' ? borrowerSignTime : '02 Jun 2026 at 14:31:29 IST (UTC+05:30)';
    const safeCoBorrower1 = typeof coBorrower1 !== 'undefined' ? coBorrower1 : 'HARJINDER SINGH';
    const safeCoBorrowerSignTime = typeof coBorrowerSignTime !== 'undefined' ? coBorrowerSignTime : '02 Jun 2026 at 14:36:43 IST (UTC+05:30)';
    const safeStampDuty = typeof stampDuty !== 'undefined' ? stampDuty : '304';
    const safeStampDutyPaperNos = typeof stampDutyPaperNos !== 'undefined' ? stampDutyPaperNos : 'IN-PB39794908798599Y to IN-PB39857530112782Y';
  %>

  <!-- ================= PAGE 1: INSTALMENTS 0 TO 31 ================= -->
  <div class="page">
    <div class="annex-title">ANNEX C</div>
    
    <div class="title">
      REPAYMENT SCHEDULE UNDER EQUATED PERIODIC INSTALMENT FOR THE<br>
      LOAN ILLUSTRATED IN ANNEX B
    </div>

    <table>
      <thead>
        <tr>
          <th style="width: 14%;">Instalment No.</th>
          <th style="width: 25%;">Outstanding Principal<br>(in Rupees)</th>
          <th style="width: 20%;">Principal<br>(in Rupees)</th>
          <th style="width: 20%;">Interest<br>(in Rupees)</th>
          <th style="width: 21%;">Instalment<br>(in Rupees)</th>
        </tr>
      </thead>
      <tbody>
        <% if (typeof schedule !== 'undefined' && schedule && schedule.length > 0) { %>
          <% schedule.slice(0, 32).forEach(function(row) { %>
            <tr>
              <td><%= row.instNo %></td>
              <td><%= parseFloat(row.outstandingPrincipal).toLocaleString('en-IN') %></td>
              <td><%= parseFloat(row.principalComponent).toLocaleString('en-IN') %></td>
              <td><%= parseFloat(row.interestComponent).toLocaleString('en-IN') %></td>
              <td><%= parseFloat(row.installment).toLocaleString('en-IN') %></td>
            </tr>
          <% }); %>
        <% } else { %>
          <!-- Default fallback values to make route checkable instantly -->
          <tr>
            <td>0</td>
            <td>1,08,946</td>
            <td>0</td>
            <td>353</td>
            <td>353</td>
          </tr>
          <% for (let i = 1; i <= 31; i++) { %>
            <tr>
              <td><%= i %></td>
              <td><%= (108946 - (i * 1954)).toLocaleString('en-IN') %></td>
              <td>1,954</td>
              <td>2,642</td>
              <td>4,596</td>
            </tr>
          <% } %>
        <% } %>
      </tbody>
    </table>

    <!-- Bottom Signatures & Legal Footer -->
    <div class="footer-container">
      <div class="esign-container">
        <div class="esign-block">
          <div class="esign-name"><%= safeBorrowerName %></div>
          <div><%= safeBorrowerSignTime %></div>
          <div>Aadhaar Sign</div>
          <div class="esign-underline">eSign by Melento</div>
        </div>
        <div class="esign-block esign-block-right">
          <div class="esign-name"><%= safeCoBorrower1 %></div>
          <div><%= safeCoBorrowerSignTime %></div>
          <div>Aadhaar Sign</div>
          <div class="esign-underline">eSign by Melento</div>
        </div>
      </div>
      
      <div class="stamp-duty-text">
        The Stamp Duty of total value INR <%= safeStampDuty %> has been paid for this Agreement vide Stamp Paper Nos (<%= safeStampDutyPaperNos %>) in<br>
        no sequential order, and the same has been mentioned in the subsequent page of this Agreement.
      </div>
    </div>
  </div>

  <!-- ================= PAGE 2: INSTALMENTS 32 TO 36 ================= -->
  <div class="page">
    <div style="height: 40px;"></div> <!-- Spacing at top to match layout -->
    
    <table>
      <tbody>
        <% if (typeof schedule !== 'undefined' && schedule && schedule.length > 32) { %>
          <% schedule.slice(32).forEach(function(row) { %>
            <tr>
              <td style="width: 14%;"><%= row.instNo %></td>
              <td style="width: 25%;"><%= parseFloat(row.outstandingPrincipal).toLocaleString('en-IN') %></td>
              <td style="width: 20%;"><%= parseFloat(row.principalComponent).toLocaleString('en-IN') %></td>
              <td style="width: 20%;"><%= parseFloat(row.interestComponent).toLocaleString('en-IN') %></td>
              <td style="width: 21%;"><%= parseFloat(row.installment).toLocaleString('en-IN') %></td>
            </tr>
          <% }); %>
        <% } else { %>
          <!-- Fallback page 2 rows -->
          <% for (let i = 32; i <= 35; i++) { %>
            <tr>
              <td style="width: 14%;"><%= i %></td>
              <td style="width: 25%;"><%= (21490 - ((i - 31) * 4057)).toLocaleString('en-IN') %></td>
              <td style="width: 20%;">4,057</td>
              <td style="width: 20%;">539</td>
              <td style="width: 21%;">4,596</td>
            </tr>
          <% } %>
          <tr>
            <td style="width: 14%;">36</td>
            <td style="width: 25%;">0</td>
            <td style="width: 20%;">4,590</td>
            <td style="width: 20%;">116</td>
            <td style="width: 21%;">4,706</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <!-- Bottom Signatures & Legal Footer -->
    <div class="footer-container">
      <div class="esign-container">
        <div class="esign-block">
          <div class="esign-name"><%= safeBorrowerName %></div>
          <div><%= safeBorrowerSignTime %></div>
          <div>Aadhaar Sign</div>
          <div class="esign-underline">eSign by Melento</div>
        </div>
        <div class="esign-block esign-block-right">
          <div class="esign-name"><%= safeCoBorrower1 %></div>
          <div><%= safeCoBorrowerSignTime %></div>
          <div>Aadhaar Sign</div>
          <div class="esign-underline">eSign by Melento</div>
        </div>
      </div>
      
      <div class="stamp-duty-text">
        The Stamp Duty of total value INR <%= safeStampDuty %> has been paid for this Agreement vide Stamp Paper Nos (<%= safeStampDutyPaperNos %>) in<br>
        no sequential order, and the same has been mentioned in the subsequent page of this Agreement.
      </div>
    </div>
  </div>

</body>
</html>
