<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Loan Application Form - Satin Finserv Limited</title>
  <style>
    @page {
      size: A4;
      margin: 0;
    }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background-color: #ffffff;
      font-family: 'Times New Roman', Times, serif;
      -webkit-print-color-adjust: exact;
    }

    .page {
      position: relative;
      width: 210mm;
      min-height: 297mm;
      padding: 12mm 14mm 14mm 14mm;
      box-sizing: border-box;
      page-break-after: always;
      overflow: hidden;
      color: #000000;
      margin: 0 auto;
      font-size: 10pt;
    }

    .page:last-child {
      page-break-after: avoid;
    }

    /* Header */
    .top-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 8px;
    }

    .top-header .logo img {
      height: 34px;
      max-width: 150px;
      object-fit: contain;
    }

    .top-header .form-title {
      font-size: 11pt;
      font-weight: bold;
      text-decoration: underline;
      padding-top: 6px;
    }

    .top-header .date {
      font-size: 10pt;
      padding-top: 6px;
    }

    /* Branch table */
    table.branch-table {
      border-collapse: collapse;
      width: 55%;
      margin: 4px 0 4px auto;
    }

    table.branch-table td {
      border: 1px solid #000000;
      padding: 3px 6px;
      font-size: 9.5pt;
      height: 16px;
    }

    table.branch-table td.lbl {
      width: 38%;
    }

    /* Section headings */
    .section-title {
      font-size: 10.5pt;
      font-weight: bold;
      text-decoration: underline;
      margin: 14px 0 10px 0;
    }

    .section-bar {
      background-color: #7d00b3;
      color: #ffffff;
      text-align: center;
      font-weight: bold;
      font-size: 10.5pt;
      padding: 4px 0;
      margin: 14px 0 10px 0;
    }

    .section-bar.teal {
      background-color: #9fd8d3;
      color: #000000;
      text-align: left;
      padding-left: 8px;
    }

    /* Form fields */
    .field-row {
      margin-bottom: 12px;
      line-height: 1.5;
    }

    .fill {
      display: inline-block;
      border-bottom: 1px solid #000000;
      min-width: 120px;
      height: 13px;
    }

    .fill.grow { min-width: 300px; }
    .fill.wide { min-width: 420px; }
    .fill.xwide { min-width: 560px; }
    .fill.sm { min-width: 70px; }

    .chk {
      display: inline-block;
      width: 12px;
      height: 12px;
      border: 1px solid #000000;
      vertical-align: middle;
      margin: 0 3px 0 6px;
      box-sizing: border-box;
      font-size: 9px;
      text-align: center;
      line-height: 11px;
    }

    .name-cols {
      display: flex;
      gap: 20px;
      margin-top: 2px;
    }

    .name-cols .nc {
      flex: 1;
      text-align: center;
    }

    .name-cols .nc .line {
      border-bottom: 1px solid #000000;
      height: 14px;
      margin-bottom: 2px;
    }

    .name-cols .nc .cap {
      font-size: 8.5pt;
    }

    /* Charges table */
    table.charges-table {
      border-collapse: collapse;
      width: 100%;
      margin: 6px 0 12px 0;
    }

    table.charges-table td {
      border: 1px solid #000000;
      padding: 4px 6px;
      font-size: 9.5pt;
    }

    table.charges-table td.amt {
      width: 32%;
    }

    /* References table */
    table.ref-table {
      border-collapse: collapse;
      width: 100%;
      margin: 4px 0 10px 0;
    }

    table.ref-table td {
      border: 1px solid #000000;
      padding: 6px 8px;
      font-size: 9.5pt;
      vertical-align: top;
      width: 50%;
    }

    table.ref-table td .rline {
      border-bottom: 1px solid #000000;
      height: 13px;
      margin: 3px 0 8px 0;
    }

    .box-received {
      border: 1px solid #000000;
      padding: 8px 10px;
      font-size: 10pt;
      line-height: 1.6;
      text-align: justify;
      margin-bottom: 6px;
    }

    .summary-box {
      border: 1px solid #000000;
      padding: 8px 10px;
      margin-top: 6px;
    }

    p.para {
      font-size: 10pt;
      line-height: 1.5;
      text-align: justify;
      margin: 0 0 10px 0;
    }

    .foot-note {
      font-size: 9.5pt;
      line-height: 1.4;
      border-top: 1px dashed #000000;
      margin-top: 12px;
      padding-top: 6px;
      text-align: center;
    }
  </style>
</head>
<body>

