    </div>

    <div class="field-row">Mothers Full Name: <span class="fill xwide"><%= safeCo1MotherName %></span></div>
    <div class="field-row">Fathers Full Name: <span class="fill xwide"><%= safeCo1FatherName %></span></div>
    <div class="field-row">Spouse Full Name: <span class="fill xwide"><%= safeCo1SpouseName %></span></div>
    <div class="field-row">Relationship with Borrower: <span class="fill wide"><%= safeCo1RelationWithBorrower %></span></div>

    <div class="field-row">
      Date of Birth: <span class="fill"><%= safeCo1Dob %></span> &nbsp; Age : <span class="fill sm"><%= safeCo1Age %></span> ( In Yrs.) Mobile: <span class="fill grow"><%= safeCo1Mobile %></span>
